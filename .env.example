# Optional GitHub token — raises the rate limit to 5,000 req/hr and enables
# private repos. Public-repo watching works without it.
GITHUB_TOKEN=ghp_optional_for_higher_limits

# Secrets referenced as ${VAR} inside channel URLs (resolved at send time).
NTFY_TOKEN=tk_replace_me
DISCORD_WEBHOOK_ID=replace_me
DISCORD_WEBHOOK_TOKEN=replace_me

# Where SQLite state lives (inside the container this is a mounted volume).
DATABASE_URL=sqlite:////data/github-watcher.db
LOG_LEVEL=INFO

# Timezone for stored/displayed timestamps. Set to your local zone to match the
# host, e.g. TZ=America/New_York. Defaults to UTC.
TZ=UTC
